---
import BaseLayout from './BaseLayout.astro';
import NavBar from '../components/NavBar';
import Footer from '../components/Footer.astro';

interface Props {
  translations: any;
  slug: string;
  lang?: string;
}

const { translations, slug, lang = 'en' } = Astro.props;
const t = translations[lang] || translations.en;
const canonical = `https://spinix.so/vs/${slug}`;

// Normalize pricing: some pages use competitor name as key instead of "competitor"
if (t.pricing && !t.pricing.competitor) {
  const compKey = Object.keys(t.pricing).find(k => k !== 'title' && k !== 'spinix' && k !== 'revix');
  if (compKey) t.pricing.competitor = t.pricing[compKey];
}
if (t.pricing && !t.pricing.spinix && t.pricing.revix) {
  t.pricing.spinix = t.pricing.revix;
}
---

<BaseLayout title={t.meta.title} description={t.meta.description} canonical={canonical} lang={lang}>
  <NavBar lang={lang} client:load />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": t.meta.title,
    "description": t.meta.description,
    "author": { "@type": "Organization", "name": "SpiniX" },
    "publisher": { "@type": "Organization", "name": "SpiniX" }
  })} />
  {t.faq?.items && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": t.faq.items.map((item: any) => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": { "@type": "Answer", "text": item.a }
      }))
    })} />
  )}

  <!-- Hero -->
  {t.hero && (
    <section class="bg-gradient-to-br from-sky-50 via-white to-cyan-50 pt-12 pb-10">
      <div class="max-w-4xl mx-auto px-4 text-center animate-fade-in-up">
        {t.hero.badge && <span class="inline-block text-sm font-semibold text-sky-600 uppercase tracking-wide mb-3">{t.hero.badge}</span>}
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4" style="font-family: Montserrat, sans-serif">{t.hero.title}</h1>
        {t.hero.subtitle && <p class="text-lg text-gray-600 mb-2">{t.hero.subtitle}</p>}
        {t.hero.updatedDate && <p class="text-sm text-gray-400">{t.hero.updatedDate}</p>}
      </div>
    </section>
  )}

  <!-- Quick Verdict (optional) -->
  {t.verdict?.spinix && (
    <section class="py-12 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: Montserrat, sans-serif">{t.verdict.title}</h2>
        <div class="grid md:grid-cols-2 gap-6 stagger-children">
          <div class="rounded-xl bg-green-50 border-2 border-green-200 p-6">
            <h3 class="font-bold text-green-800 mb-4">{t.verdict.spinix.title}</h3>
            <ul class="space-y-2">
              {t.verdict.spinix.points.map((point: string) => (
                <li class="text-green-700 text-sm flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {point}
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-xl bg-gray-50 border border-gray-200 p-6">
            <h3 class="font-bold text-gray-700 mb-4">{t.verdict.competitor.title}</h3>
            <ul class="space-y-2">
              {t.verdict.competitor.points.map((point: string) => (
                <li class="text-gray-600 text-sm flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                  {point}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- TLDR (alternative to verdict, used by some pages) -->
  {t.tldr && !t.verdict && (
    <section class="py-12 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: Montserrat, sans-serif">{t.tldr.title}</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {t.tldr.revix && (
            <div class="rounded-xl bg-green-50 border-2 border-green-200 p-6">
              <h3 class="font-bold text-green-800 mb-3">Revix</h3>
              <p class="text-green-700 text-sm leading-relaxed">{t.tldr.revix}</p>
            </div>
          )}
          {t.tldr.birdeye && (
            <div class="rounded-xl bg-gray-50 border border-gray-200 p-6">
              <h3 class="font-bold text-gray-700 mb-3">{Object.keys(t.tldr).find(k => k !== 'title' && k !== 'revix' && k !== 'spinix') || 'Competitor'}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{t.tldr.birdeye || t.tldr[Object.keys(t.tldr).find(k => k !== 'title' && k !== 'revix' && k !== 'spinix') || '']}</p>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Feature Comparison Table (optional) -->
  {t.comparison?.rows && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: Montserrat, sans-serif">{t.comparison.title}</h2>
        <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
          <table class="w-full bg-white">
            <thead>
              <tr class="bg-sky-600 text-white">
                {(t.comparison.headers || ['Feature', 'SpiniX', 'Competitor']).map((h: string, i: number) => (
                  <th class={`px-4 py-3 text-left text-sm font-semibold ${i === 1 ? 'bg-sky-700' : ''}`}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {t.comparison.rows.map((row: any) => (
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-3 text-sm text-gray-700 font-medium">{row.feature}</td>
                  <td class={`px-4 py-3 text-sm ${row.winner === 'spinix' ? 'text-green-700 font-semibold bg-green-50' : 'text-gray-600'}`}>{row.spinix}</td>
                  <td class={`px-4 py-3 text-sm ${row.winner === 'competitor' ? 'text-green-700 font-semibold bg-green-50' : 'text-gray-600'}`}>{row.competitor}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- Pricing (optional) -->
  {t.pricing?.spinix && (
    <section class="py-12 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: Montserrat, sans-serif">{t.pricing.title}</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="rounded-xl border-2 border-sky-500 bg-sky-50 p-6">
            <h3 class="text-xl font-bold text-sky-700 mb-4">{t.pricing.spinix.name}</h3>
            <div class="space-y-4">
              {t.pricing.spinix.plans.map((plan: any) => (
                <div class="bg-white rounded-lg p-4">
                  <div class="flex justify-between items-center mb-2">
                    <span class="font-semibold text-gray-900">{plan.name}</span>
                    <span class="text-sky-600 font-bold">{plan.price}</span>
                  </div>
                  {plan.features && (
                    <ul class="text-xs text-gray-600 space-y-1">
                      {plan.features.map((f: string) => <li>{`• ${f}`}</li>)}
                    </ul>
                  )}
                </div>
              ))}
            </div>
            {t.pricing.spinix.note && <p class="text-xs text-sky-700 mt-4 font-medium">{t.pricing.spinix.note}</p>}
          </div>
          <div class="rounded-xl border border-gray-200 bg-gray-50 p-6">
            <h3 class="text-xl font-bold text-gray-700 mb-4">{t.pricing.competitor.name}</h3>
            <div class="space-y-4">
              {t.pricing.competitor.plans.map((plan: any) => (
                <div class="bg-white rounded-lg p-4">
                  <div class="flex justify-between items-center mb-2">
                    <span class="font-semibold text-gray-900">{plan.name}</span>
                    <span class="text-gray-600 font-bold">{plan.price}</span>
                  </div>
                  {plan.features && (
                    <ul class="text-xs text-gray-600 space-y-1">
                      {plan.features.map((f: string) => <li>{`• ${f}`}</li>)}
                    </ul>
                  )}
                </div>
              ))}
            </div>
            {t.pricing.competitor.note && <p class="text-xs text-gray-500 mt-4">{t.pricing.competitor.note}</p>}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Details (optional) -->
  {t.details?.sections && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: Montserrat, sans-serif">{t.details.title}</h2>
        <div class="space-y-6">
          {t.details.sections.map((section: any) => (
            <div class="bg-white rounded-xl border border-gray-100 p-6">
              <h3 class="font-bold text-gray-900 mb-2">{section.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{section.content}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Stats (optional) -->
  {t.stats?.items && (
    <section class="py-12 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: Montserrat, sans-serif">{t.stats.title}</h2>
        <div class="overflow-x-auto rounded-xl border border-gray-200">
          <table class="w-full bg-white text-sm">
            <thead><tr class="bg-gray-50 text-gray-600"><th class="px-4 py-3 text-left">Metric</th><th class="px-4 py-3 text-left">SpiniX</th><th class="px-4 py-3 text-left">Competitor</th></tr></thead>
            <tbody>
              {t.stats.items.map((item: any) => (
                <tr class="border-t"><td class="px-4 py-3 font-medium text-gray-700">{item.label}</td><td class="px-4 py-3 text-green-700 font-semibold">{item.spinix}</td><td class="px-4 py-3 text-gray-600">{item.competitor}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ (optional) -->
  {t.faq?.items && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: Montserrat, sans-serif">{t.faq.title}</h2>
        <div class="space-y-3">
          {t.faq.items.map((item: any) => (
            <details class="bg-white rounded-xl border border-gray-100 group">
              <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-gray-900 flex items-center justify-between">
                {item.q}
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <p class="px-6 pb-4 text-sm text-gray-600 leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA (optional) -->
  {t.cta && (
    <section class="bg-gradient-to-br from-sky-500 to-cyan-500 py-12">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif">{t.cta.title}</h2>
        {t.cta.subtitle && <p class="text-sky-100 mb-6">{t.cta.subtitle}</p>}
        <a href="https://spinix.so/auth?mode=register" class="inline-flex items-center px-8 py-4 rounded-xl bg-white hover:bg-gray-100 text-sky-600 font-semibold text-lg shadow-lg transition">
          {t.cta.button}
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        {t.cta.badges && (
          <div class="mt-6 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-sky-100">
            {t.cta.badges.map((b: string) => <span>{`✓ ${b}`}</span>)}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Generic content slot for pages with custom sections -->
  <slot />

  <Footer lang={lang} />
</BaseLayout>
